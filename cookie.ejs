const ex = require("express")
const ses = require("express-session")
const cp = require("cookie-parser")

const app = ex()

app.use(cp())

app.use(ses({
    secret:"abc",
    resave:false,
    saveUninitialized:true
}))

app.get("/",(req,res)=>{

    if(req.session.v)
    {
        req.session.v++
        res.send("Visits: "+req.session.v)
    }
    else
    {
        req.session.v = 1
        res.send("First Visit")
    }

})

app.listen(3000,()=>console.log("Run"))